LoadAllSettings() {
    global TokenText, TokenSendEnter, IntroText, IntroSendEnter
    if FileExist(SettingsIni) {
        TokenText := IniRead(SettingsIni, "Token", "Text", "")
        TokenSendEnter := IniRead(SettingsIni, "Token", "SendEnter", "1") = "1"
        IntroText := IniRead(SettingsIni, "Intro", "Text", "")
        IntroSendEnter := IniRead(SettingsIni, "Intro", "SendEnter", "1") = "1"
    } else {
        TokenText := "Ваш текст жетона"
        TokenSendEnter := true
        IntroText := "Ваш текст представления"
        IntroSendEnter := true
    }
}

SaveAllSettings() {
    IniWrite(TokenText, SettingsIni, "Token", "Text")
    IniWrite(TokenSendEnter ? "1" : "0", SettingsIni, "Token", "SendEnter")
    IniWrite(IntroText, SettingsIni, "Intro", "Text")
    IniWrite(IntroSendEnter ? "1" : "0", SettingsIni, "Intro", "SendEnter")
}

