ForceTopMost(hwnd) {
    if !hwnd
        return
    WinSetAlwaysOnTop(1, "ahk_id " hwnd)
    DllCall("SetWindowPos", "Ptr", hwnd, "Ptr", -1, "Int", 0, "Int", 0, "Int", 0, "Int", 0, "UInt", 0x0003)
    DllCall("BringWindowToTop", "Ptr", hwnd)
    DllCall("SetForegroundWindow", "Ptr", hwnd)
    WinActivate("ahk_id " hwnd)
}

CenterWindow(hwnd, Width, Height) {
    MonitorGetWorkArea(1, &Left, &Top, &Right, &Bottom)
    X := (Right - Left - Width) // 2
    Y := (Bottom - Top - Height) // 2
    WinMove(X, Y, Width, Height, "ahk_id " hwnd)
}

ParseIniContent(content) {
    data := []
    currentTitle := "", currentDesc := "", currentFine := ""
    Loop Parse, content, "`n", "`r" {
        line := Trim(A_LoopField)
        if RegExMatch(line, "^\[.*\]$") and currentTitle != "" {
            data.Push({Title: currentTitle, Desc: currentDesc, Fine: currentFine})
            currentTitle := "", currentDesc := "", currentFine := ""
            continue
        }
        if RegExMatch(line, "^Title=(.*)$", &match)
            currentTitle := match[1]
        else if RegExMatch(line, "^Desc=(.*)$", &match)
            currentDesc := match[1]
        else if RegExMatch(line, "^Fine=(.*)$", &match)
            currentFine := match[1]
    }
    if currentTitle != ""
        data.Push({Title: currentTitle, Desc: currentDesc, Fine: currentFine})
    return data
}

CreateScreenshotBaseDir() {
    global ScreenshotBaseDir
    if !DirExist(ScreenshotBaseDir)
        DirCreate(ScreenshotBaseDir)
}

CreateScreenshotSubfolder(folderName) {
    global ScreenshotBaseDir
    CreateScreenshotBaseDir()
    folderPath := ScreenshotBaseDir "\" folderName
    if !DirExist(folderPath)
        DirCreate(folderPath)
    return folderPath
}

TakeScreenshot(folderName) {
    folderPath := CreateScreenshotSubfolder(folderName)
    timestamp := FormatTime(, "yyyy-MM-dd_HH-mm-ss")
    filePath := folderPath "\" folderName "_" timestamp ".png"
    
    ; Экранируем обратные слеши для PowerShell
    filePathPosh := StrReplace(filePath, "\", "\\")
    
    ; Однострочная команда PowerShell (без ошибок синтаксиса)
    psCmd := "Add-Type -AssemblyName System.Windows.Forms; Add-Type -AssemblyName System.Drawing; $screen = [System.Windows.Forms.SystemInformation]::VirtualScreen; $bmp = New-Object System.Drawing.Bitmap $screen.Width, $screen.Height; $g = [System.Drawing.Graphics]::FromImage($bmp); $g.CopyFromScreen($screen.X, $screen.Y, 0, 0, $bmp.Size); $bmp.Save('" filePathPosh "'); $g.Dispose(); $bmp.Dispose()"
    
    RunWait('powershell -NoProfile -ExecutionPolicy Bypass -Command "' psCmd '"', , "Hide")
    
    return filePath
}

