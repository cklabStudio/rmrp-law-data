LoadLawData(FilterText := "") {
    global CurrentMode, LV, UK_Data, KoAP_Data
    LV.Delete()
    data := (CurrentMode == "UK") ? UK_Data : KoAP_Data
    for item in data {
        if (FilterText = "" 
            || InStr(item.Title, FilterText) 
            || InStr(item.Desc, FilterText) 
            || InStr(item.Fine, FilterText)) {
            LV.Add(, item.Title, item.Desc, item.Fine)
        }
    }
}

