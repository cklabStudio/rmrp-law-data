SendToken(*) {
    global TokenText, TokenSendEnter
    if (TokenText = "")
        return
    oldClip := ClipboardAll()
    A_Clipboard := TokenText
    Send("{T}")
    Sleep 80
    Send("^v")
    Sleep 50
    A_Clipboard := oldClip
    if TokenSendEnter
        Send("{Enter}")
}

SendIntro(*) {
    global IntroText, IntroSendEnter
    if (IntroText = "")
        return
    oldClip := ClipboardAll()
    A_Clipboard := IntroText
    Send("{T}")
    Sleep 80
    Send("^v")
    Sleep 50
    A_Clipboard := oldClip
    if IntroSendEnter
        Send("{Enter}")
}

